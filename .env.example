# Terbium v2 Backend Configuration
# Copy this file to .env and configure according to your deployment needs

# ============================================================================
# MASQR Configuration (Anti Link Leaking System)
# ============================================================================
# MASQR helps protect user privacy by preventing direct connections to external services
# Enable this in educational or privacy-sensitive environments

# Enable or disable MASQR (true/false)
MASQR=false

# License server URL (required if MASQR=true)
LICENSE_SERVER_URL=https://masqr-license-server.example.com

# Comma-separated list of domains to bypass MASQR protection
# Common entries: localhost, your own domain names, trusted API endpoints
WHITELISTED_DOMAINS=localhost,127.0.0.1

# ============================================================================
# Server Configuration
# ============================================================================

# Port for the main Terbium HTTP server
PORT=3000

# Port for the Wisp WebSocket server (proxy connections)
WISP_PORT=6001

# ============================================================================
# Additional Notes
# ============================================================================
# - Wisp endpoint path is hardcoded to /wisp/ and cannot be changed
# - DNS servers are hardcoded to 1.1.1.3 and 1.0.0.3 (Cloudflare malware blocking)
# - Changes to .env require a server restart
# - Never commit .env to version control - add it to .gitignore
